# ========================
# TAILS OF BIJAPUR GITIGNORE
# ========================

# 1. Dependencies (Catches ALL node_modules everywhere)
node_modules/
**/node_modules/

# 2. Environment Variables (Protects your database passwords)
.env
.env.*
**/.env

# 3. Build Outputs (Prevents Vite's compiled files from bloating GitHub)
dist/
frontend/dist/
build/

# 4. Uploaded files (Prevents user photos from hitting GitHub)
uploads/
api/uploads/
backend/uploads/

# 5. Logs & OS Files
*.log
npm-debug.log*
.DS_Store
Thumbs.db